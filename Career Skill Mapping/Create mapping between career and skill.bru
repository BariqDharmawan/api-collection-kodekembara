meta {
  name: Create mapping between career and skill
  type: http
  seq: 2
}

post {
  url: {{APP_DOMAIN}}/career-skill-mapping
  body: multipartForm
  auth: inherit
}

headers {
  Accept: application/json
}

body:multipart-form {
  career_available_id: 50c5558a-deca-4fdc-9440-07a47749eb52
  skill_available_id: eee6213e-2b69-451c-a65c-2b827e97d50c
  belief_weight: 1
  min_experience_months: 10
}

settings {
  encodeUrl: true
  timeout: 0
}
